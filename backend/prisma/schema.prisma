generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 🔴 ENUMS: MÁQUINAS DE ESTADO
// ==========================================

enum EstadoUsuario {
  ACTIVO
  INACTIVO
  BLOQUEADO
}

enum EstadoEmpleado {
  ACTIVO
  VACACIONES
  LICENCIA
  DESPEDIDO
  RENUNCIADO
}

enum EstadoProducto {
  ACTIVO
  AGOTADO
  DESCONTINUADO
  EN_TRANSITO
}

enum EstadoPedido {
  PENDIENTE
  PAGADO
  EN_PREPARACION
  ENVIADO
  ENTREGADO
  CANCELADO
  DEVOLUCION
}

// ==========================================
// 🏭 MÓDULO DE INVENTARIO Y COMPRAS
// ==========================================

model Proveedor {
  id          String     @id @default(uuid())
  razonSocial String
  ruc         String     @unique
  pais        String     
  contacto    String?
  activo      Boolean    @default(true) 
  productos   Producto[] 
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Producto {
  id          String         @id @default(uuid())
  nombre      String
  precio      Float
  estado      EstadoProducto @default(ACTIVO) 
  
  categoria   Categoria      @relation(fields: [categoriaId], references: [id])
  categoriaId String
  
  imagen      String?   
  marca       String?  
  detalles    String?
  
  proveedor   Proveedor?     @relation(fields: [proveedorId], references: [id])
  proveedorId String?    
  
  detallesPed DetallePedido[] 
  inventarios InventarioSede[] 

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Categoria {
  id        String     @id @default(uuid())
  nombre    String     @unique 
  productos Producto[]
  activo    Boolean    @default(true)
}

// ==========================================
// 🏢 MÓDULO DE RECURSOS HUMANOS (ERP)
// ==========================================

model Sede {
  id          String     @id @default(uuid())
  nombre      String     
  direccion   String
  ciudad      String
  activo      Boolean    @default(true)
  
  empleados   Empleado[] 
  pedidos     Pedido[]   
  inventarios InventarioSede[] 
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Empleado {
  id               String         @id @default(uuid())
  dni              String         @unique
  telefono         String?
  cargo            String   
  salario          Float
  estado           EstadoEmpleado @default(ACTIVO) // <--- Estado Profesional
  fechaContratacion DateTime       @default(now())

  sedeId           String
  sede             Sede           @relation(fields: [sedeId], references: [id])

  usuarioId        String         @unique
  usuario          Usuario        @relation(fields: [usuarioId], references: [id])

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ==========================================
// 🛒 MÓDULO DE E-COMMERCE Y SEGURIDAD
// ==========================================

model Usuario {
  id        String        @id @default(uuid())
  nombre    String
  apellido  String?
  email     String        @unique
  password  String    
  rol       String        @default("CLIENTE") 
  estado    EstadoUsuario @default(ACTIVO) // <--- Estado de Seguridad
  
  empleado  Empleado? 
  pedidos   Pedido[]  

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Pedido {
  id         String       @id @default(uuid())
  total      Float
  estado     EstadoPedido @default(PENDIENTE) // <--- Flujo de Venta
  
  usuarioId  String
  usuario    Usuario      @relation(fields: [usuarioId], references: [id])

  sedeId     String?
  sede       Sede?        @relation(fields: [sedeId], references: [id])
  
  detalles   DetallePedido[]
  
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model DetallePedido {
  id         String   @id @default(uuid())
  cantidad   Int
  precioFijo Float    
  
  pedidoId   String
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])
}

model InventarioSede {
  id         String   @id @default(uuid())
  cantidad   Int      @default(0) 

  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])

  sedeId     String
  sede       Sede     @relation(fields: [sedeId], references: [id])

  @@unique([productoId, sedeId]) 
}