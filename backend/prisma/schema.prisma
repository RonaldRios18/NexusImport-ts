generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"  // <-- ESTA ES LA CLAVE DE PRISMA 7
}

datasource db {
  provider = "postgresql"
}

model Producto {
  id        String   @id @default(uuid())
  nombre    String
  precio    Float
  stock     Int
  categoria String
  marca     String?
  detalles  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}