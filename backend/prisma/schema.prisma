generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
}

model Producto {
  id        String   @id @default(uuid())
  nombre    String
  precio    Float
  stock     Int
  categoria String
  marca     String?
  detalles  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}